{
  "name": "max-coder",
  "version": "0.1.0",
  "description": "Max Coder — a local-first AI coding agent.",
  "type": "module",
  "bin": {
    "maxcoder": "dist/maxcoder"
  },
  "scripts": {
    "start": "bun run src/cli.ts",
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --compile --outfile dist/maxcoder",
    "build:darwin-arm64": "bun build src/cli.ts --compile --target=bun-darwin-arm64 --outfile dist/maxcoder-darwin-arm64",
    "build:darwin-x64": "bun build src/cli.ts --compile --target=bun-darwin-x64 --outfile dist/maxcoder-darwin-x64",
    "build:linux-x64": "bun build src/cli.ts --compile --target=bun-linux-x64 --outfile dist/maxcoder-linux-x64",
    "build:all": "bun run build:darwin-arm64 && bun run build:darwin-x64 && bun run build:linux-x64"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.14"
  }
}
